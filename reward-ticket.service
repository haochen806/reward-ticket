[Unit]
Description=Alaska Award Ticket Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/reward-ticket
ExecStart=/home/pi/reward-ticket/venv/bin/python -m src.main
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
